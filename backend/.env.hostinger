# ============================================================
#  PERSEO — Backend ENV para Hostinger
#  Copiá este contenido en las Variables de Entorno del backend
# ============================================================

NODE_ENV=production

# ─── Puerto (Hostinger lo inyecta automáticamente) ──────────
# Hostinger sobreescribe PORT. No lo cambies aquí.
PORT=3000

# ─── Base de datos PostgreSQL ────────────────────────────────
# Usá los datos de tu DB de Hostinger o Supabase/Neon
DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@HOST:5432/NOMBRE_DB

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-minimo-32-caracteres-aleatorios-aqui

# ─── WhatsApp — Evolution API ────────────────────────────────
# Si no usás Evolution en Hostinger, dejá estas vacías
EVOLUTION_API_URL=https://TU_EVOLUTION_API_URL
EVOLUTION_API_KEY=tu-api-key-evolution
EVOLUTION_SERVER_URL=https://TU_DOMINIO_BACKEND/evolution

# ─── URLs ─────────────────────────────────────────────────────
APP_URL=https://TU_DOMINIO_FRONTEND
BACKEND_URL=https://TU_DOMINIO_BACKEND/api

# ─── Google Sheets (opcional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://TU_DOMINIO_BACKEND/api/sheets/callback

# ─── Stripe (opcional) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─── OpenAI (para scoring IA) ────────────────────────────────
OPENAI_API_KEY_FALLBACK=sk-...

# ─── Demo seed — SIEMPRE false en producción ─────────────────
SEED_DEMO=false

# ─── Meta (opcional) ─────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# ─── 360dialog (opcional) ────────────────────────────────────
DIALOG360_PARTNER_ID=
DIALOG360_PARTNER_TOKEN=

LOG_PRETTY=false
